# Python
scripts/.venv/
__pycache__/
*.pyc

# Credentials — never commit
scripts/cts.ini
*.env
.env

# macOS noise
.DS_Store

# Personal data — never publish to public repo
# (CalTopo map dumps with personal planning, Kyle's climb tracks, etc.)
caltopo/
# Ignore all GPX data EXCEPT the per-peak waypoint configs (hand-researched
# TH/landmark coords — authoritative input to build_peak_gpx.py, not bulky
# derived data). Idiom: ignore files, descend into subdirs, keep peaks.yml.
gpx/*
!gpx/*/
gpx/*/*
!gpx/*/peaks.yml
!gpx/*/sources.json
!gpx/*/route_accepted.yml

# Local Claude Code project state
.claude/

# Playwright MCP browser session scratch
.playwright-mcp/

# Scratch JSON dumps from research sessions (root-level only — anything in docs/ is real)
/*.json

# MkDocs build output
site/
_local_test/
notes/

# research_peak.py working skeletons (intermediate, not published)
docs/peaks/*.skeleton.md

# tr manifests from sweep_gpx (intermediate)
gpx/*/tr_manifest.md

# transient sweep_peak batch state
tmp_*.json
tmp_*.flag
